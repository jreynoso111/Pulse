{
  "compilerOptions": {
    "allowJs": true,
    "checkJs": false,
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": false,
    "target": "ES2022",
    "types": ["vite/client", "vitest/globals"]
  },
  "include": [
    "src/**/*.js",
    "src/**/*.jsx",
    "supabase/functions/**/*.ts",
    "vite.config.js",
    "eslint.config.js"
  ]
}
